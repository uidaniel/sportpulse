# scraper environment (copy to .env in this folder)

NODE_ENV=development
HEALTH_PORT=8081

# Supabase (service_role bypasses RLS — this process only, never the browser)
SUPABASE_URL=https://upfjegitipgsrovminhw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Same Redis the gateway uses (we enqueue to its wa-send queue)
REDIS_URL=redis://localhost:6379

# RapidAPI X scraper. {handle} is substituted with the screen name.
# NOTE: response mapping for your chosen provider lives in src/x/client.ts.
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_BASE_URL=https://your-provider.p.rapidapi.com
RAPIDAPI_TWEETS_PATH=/user/tweets?username={handle}

# FR-4.1 cadence + §7 cost controls
SCRAPER_POLL_INTERVAL_MS=180000
SCRAPER_POLL_CONCURRENCY=2
SCRAPER_RATE_MAX=5
SCRAPER_RATE_DURATION_MS=1000
SCRAPER_MAX_TWEETS_PER_CYCLE=5

# LOG_LEVEL=debug
