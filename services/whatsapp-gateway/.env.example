# whatsapp-gateway environment (copy to .env in this folder)

NODE_ENV=development
PORT=8080

# Shared secret the dashboard backend sends as `Authorization: Bearer <token>`.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
GATEWAY_API_TOKEN=

# Supabase (service_role bypasses RLS — this process only, never the browser)
SUPABASE_URL=https://upfjegitipgsrovminhw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Redis for BullMQ (local: redis://localhost:6379  |  Upstash: rediss://...)
REDIS_URL=redis://localhost:6379

# §7 anti-ban throttle window between channel sends (ms)
WA_SEND_MIN_DELAY_MS=3000
WA_SEND_MAX_DELAY_MS=5000

# Print the pairing QR to this terminal (handy before the dashboard exists)
WA_PRINT_QR_TERMINAL=true

# LOG_LEVEL=debug
