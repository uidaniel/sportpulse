# ---------------------------------------------------------------------------
# SportPulse environment variables  (copy to .env.local for the web app and
# .env for the worker services; never commit the filled-in files)
# ---------------------------------------------------------------------------

# --- Supabase project ---
SUPABASE_PROJECT_REF=upfjegitipgsrovminhw
# Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://upfjegitipgsrovminhw.supabase.co
# Settings -> API -> Project API keys -> anon/public  (safe in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings -> API -> Project API keys -> service_role  (SERVER/WORKERS ONLY)
SUPABASE_SERVICE_ROLE_KEY=
# Settings -> Database -> Connection string (workers needing a direct pg conn)
DATABASE_URL=

# --- Redis (session keys, scrape tracking, dedup locks) ---
REDIS_URL=redis://localhost:6379

# --- X scraper (RapidAPI) ---
# Use no-payment custom scraper route inside the Next web server:
# X_SOURCE=custom
# CUSTOM_SCRAPER_URL=http://localhost:3000
# CUSTOM_SCRAPER_TOKEN=<shared-secret>
# SCRAPER_API_TOKEN=<same shared-secret, set on web server>
# Optional on web server for authenticated X session fallback:
# X_AUTH_TOKEN=
# X_CT0=
#
# Use RapidAPI source:
# X_SOURCE=rapidapi
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_BASE_URL=
RAPIDAPI_TWEETS_PATH=/user/tweets?username={handle}
SCRAPER_POLL_INTERVAL_MS=180000   # 3 minutes (FR-4.1)

# --- WhatsApp gateway (anti-ban throttle, §7) ---
WA_SEND_MIN_DELAY_MS=3000
WA_SEND_MAX_DELAY_MS=5000

# --- Stripe billing ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
